<% content_for :title do %>Pricing | <%= installation_brand_name %><% end %>
<% content_for :meta_description do %>
  <%= installation_brand_name %> plans in UGX: Starter (free), Growth, and Business. Pay with Pesapal — M-Pesa, mobile money, and cards.
<% end %>

<h1>Pricing</h1>
<p class="lead">
  Choose a workspace plan for <%= installation_brand_name %>. All prices are in
  <strong>UGX per month</strong>. Pay securely with Pesapal after you sign in as a workspace admin.
</p>

<% if @payment_notice == 'success' %>
  <p class="notice notice-success">
    <strong>Payment received.</strong> Your plan will update shortly. Open
    <strong>Settings → Billing</strong> in the app to confirm.
  </p>
<% elsif @payment_notice == 'cancelled' %>
  <p class="notice notice-error">
    Payment was cancelled. You can try again when ready.
  </p>
<% end %>

<div class="guide-card-grid">
  <% converra_plans.each do |slug, plan| %>
    <div class="guide-card pricing-card">
      <strong><%= plan['name'] %></strong>
      <span class="pricing-price">
        <% if plan['price_ugx'].to_i.zero? %>
          Free
        <% else %>
          <%= number_with_delimiter(plan['price_ugx']) %> UGX<span class="pricing-interval">/mo</span>
        <% end %>
      </span>
      <% if plan['annual_price_ugx'].to_i.positive? %>
        <p class="pricing-annual">
          or <%= number_with_delimiter(plan['annual_price_ugx']) %> UGX/yr
          <span class="pricing-save">(save 2 months)</span>
        </p>
      <% end %>
      <ul class="pricing-features">
        <li><%= plan.dig('limits', 'agents') %> agent<%= plan.dig('limits', 'agents').to_i == 1 ? '' : 's' %></li>
        <li>All channels &amp; features included</li>
        <li><%= number_with_delimiter(plan.dig('limits', 'captain_responses')) %> Copilot replies / month (resets monthly)</li>
      </ul>
      <% if plan['price_ugx'].to_i.zero? %>
        <a href="/app/auth/signup" class="pricing-link">Get started free</a>
      <% elsif converra_billing_enabled? %>
        <a href="/app/login" class="pricing-link">Sign in to subscribe</a>
      <% else %>
        <a href="mailto:info@samabrains.com" class="pricing-link">Contact sales</a>
      <% end %>
    </div>
  <% end %>
</div>

<h2>How billing works</h2>
<ol>
  <li><a href="/app/auth/signup">Create a workspace</a> — you start on the free <strong>Starter</strong> plan.</li>
  <li>Sign in as admin and open <strong>Settings → Billing</strong>.</li>
  <li>Choose <strong>Growth</strong> or <strong>Business</strong> and pay with Pesapal (monthly or annual).</li>
  <li>Your agent seats and Copilot allowance update automatically after payment.</li>
</ol>

<p>
  Questions? <a href="mailto:info@samabrains.com">info@samabrains.com</a> ·
  <a href="<%= guide_path %>">User Guide</a>
</p>
