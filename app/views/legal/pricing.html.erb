<% content_for :landing_page, true %>
<% content_for :title do %>Pricing | <%= installation_brand_name %><% end %>
<% content_for :meta_description do %>
  <%= installation_brand_name %> plans in UGX: Starter (14-day trial), Growth, and Business. Pay with Pesapal — M-Pesa, mobile money, and cards.
<% end %>
<% onboarding_fee_ugx = 350_000 %>

<section class="landing-hero pricing-hero">
  <div class="landing-hero-glow" aria-hidden="true"></div>
  <p class="landing-eyebrow">Transparent pricing · UGX</p>
  <h1 class="landing-hero-title">Full product on every plan.<br>Scale by team size.</h1>
  <p class="landing-hero-lead">
    Choose a workspace plan for <strong><%= installation_brand_name %></strong>.
    Starter includes a <strong>14-day free trial</strong>, then 30,000 UGX/month. Upgrade to Growth or Business when you need more agents or Copilot capacity — pay securely with Pesapal after you sign in as workspace admin.
  </p>
  <div class="landing-hero-actions">
    <a href="/app/auth/signup" class="landing-btn landing-btn-primary">Start 14-day trial</a>
    <a href="<%= guide_path %>" class="landing-btn landing-btn-secondary">Setup guide</a>
  </div>
  <p class="landing-hero-note">14-day Starter trial · Then 30,000 UGX/mo · One-time onboarding: <%= number_with_delimiter(onboarding_fee_ugx) %> UGX · Operated by SamaBrains Solutions</p>
</section>

<% if @payment_notice == 'success' %>
  <div class="pricing-notice pricing-notice-success" role="status">
    <strong>Payment received.</strong> Your plan will update shortly. Open <strong>Settings → Billing</strong> in the app to confirm.
  </div>
<% elsif @payment_notice == 'cancelled' %>
  <div class="pricing-notice pricing-notice-error" role="alert">
    <strong>Payment cancelled.</strong> You can try again anytime from <strong>Settings → Billing</strong>.
  </div>
<% end %>

<section class="landing-section landing-section-alt">
  <div class="landing-section-head">
    <h2>One-time setup & training fee</h2>
    <p>All new clients are charged a one-time onboarding fee of <strong><%= number_with_delimiter(onboarding_fee_ugx) %> UGX</strong> in addition to software subscription.</p>
  </div>
  <div class="landing-card-grid landing-card-grid-2">
    <article class="landing-card landing-card-compact">
      <h3>Included</h3>
      <ul class="pricing-plan-features">
        <li>Workspace and inbox configuration</li>
        <li>WhatsApp channel setup (1 number)</li>
        <li>Labels, basic automations, and canned responses</li>
        <li>Admin + staff training sessions</li>
        <li>Go-live support window</li>
      </ul>
    </article>
    <article class="landing-card landing-card-compact">
      <h3>How it is charged</h3>
      <ul class="pricing-plan-features">
        <li>One-time fee per new workspace</li>
        <li>Separate from monthly/annual plan fee</li>
        <li>Collected during onboarding</li>
      </ul>
    </article>
  </div>
</section>

<% if converra_plans.present? %>
<section class="landing-section pricing-plans-section" id="plans">
  <div class="landing-pricing-grid pricing-plans-grid">
    <% converra_plans.each do |slug, plan| %>
      <article class="landing-price-card<%= ' landing-price-card-featured' if slug == 'growth' %>">
        <% if slug == 'growth' %><span class="landing-price-badge">Most popular</span><% end %>
        <h3><%= plan['name'] %></h3>
        <p class="landing-price-amount">
          <% if plan['trial_days'].to_i.positive? %>
            <%= number_with_delimiter(plan['price_ugx']) %> <span>UGX/mo</span>
          <% elsif plan['price_ugx'].to_i.zero? %>
            Free
          <% else %>
            <%= number_with_delimiter(plan['price_ugx']) %> <span>UGX/mo</span>
          <% end %>
        </p>
        <% if plan['trial_days'].to_i.positive? %>
          <p class="landing-price-annual landing-price-annual-muted"><%= plan['trial_days'] %>-day free trial · then billed monthly</p>
        <% elsif plan['annual_price_ugx'].to_i.positive? %>
          <p class="landing-price-annual">
            or <%= number_with_delimiter(plan['annual_price_ugx']) %> UGX/yr
            <span class="landing-price-save">Save 2 months</span>
          </p>
        <% elsif plan['price_ugx'].to_i.zero? %>
          <p class="landing-price-annual landing-price-annual-muted">Forever free · 1 workspace</p>
        <% end %>
        <ul class="pricing-plan-features">
          <li><strong><%= plan.dig('limits', 'agents') %></strong> agent<%= plan.dig('limits', 'agents').to_i == 1 ? '' : 's' %></li>
          <li><strong><%= number_with_delimiter(plan.dig('limits', 'captain_responses')) %></strong> Copilot replies / month</li>
          <li>All channels &amp; features</li>
          <li>Help Center &amp; automations</li>
          <li>+ <%= number_with_delimiter(onboarding_fee_ugx) %> UGX one-time setup &amp; training</li>
          <% if slug != 'starter' %>
            <li>Annual billing available</li>
          <% end %>
        </ul>
        <% if plan['trial_days'].to_i.positive? %>
          <a href="/app/auth/signup" class="landing-btn landing-btn-primary landing-btn-block">Start <%= plan['trial_days'] %>-day trial</a>
        <% elsif plan['price_ugx'].to_i.zero? %>
          <a href="/app/auth/signup" class="landing-btn landing-btn-primary landing-btn-block">Get started free</a>
        <% elsif converra_billing_enabled? %>
          <a href="/app/login" class="landing-btn<%= slug == 'growth' ? ' landing-btn-primary' : ' landing-btn-secondary' %> landing-btn-block">Sign in to subscribe</a>
        <% else %>
          <a href="mailto:info@samabrains.com" class="landing-btn landing-btn-secondary landing-btn-block">Contact sales</a>
        <% end %>
      </article>
    <% end %>
  </div>
  <div class="pricing-payment-row">
    <p class="landing-section-label">Pay with Pesapal</p>
    <div class="pricing-payment-pills">
      <span>Mobile money</span>
      <span>M-Pesa</span>
      <span>Visa &amp; Mastercard</span>
    </div>
  </div>
</section>
<% end %>

<section class="landing-section landing-section-alt">
  <div class="landing-section-head">
    <h2>Included on every plan</h2>
    <p>Starter, Growth, and Business ship the same powerful toolkit. You only pay for <strong>agent seats</strong> and monthly <strong>Copilot</strong> usage — not locked features.</p>
  </div>
  <div class="landing-card-grid landing-card-grid-3 pricing-includes-grid">
    <article class="landing-card">
      <span class="landing-card-icon landing-card-icon-blue" aria-hidden="true">◎</span>
      <h3>Every channel</h3>
      <p>Website chat, Gmail &amp; email, WhatsApp, Messenger, Instagram, SMS, API, and voice.</p>
    </article>
    <article class="landing-card">
      <span class="landing-card-icon landing-card-icon-violet" aria-hidden="true">✦</span>
      <h3><%= installation_captain_name %></h3>
      <p>AI auto-replies from your docs, Copilot drafts for agents, scenarios, and custom tools.</p>
    </article>
    <article class="landing-card">
      <span class="landing-card-icon landing-card-icon-emerald" aria-hidden="true">↻</span>
      <h3>Operations toolkit</h3>
      <p>Campaigns, automations, SLA policies, macros, canned responses, and custom roles.</p>
    </article>
    <article class="landing-card">
      <span class="landing-card-icon landing-card-icon-blue" aria-hidden="true">◇</span>
      <h3>Help Center</h3>
      <p>Publish a customer portal and feed the same knowledge to <%= installation_captain_name %>.</p>
    </article>
    <article class="landing-card">
      <span class="landing-card-icon landing-card-icon-violet" aria-hidden="true">◈</span>
      <h3>CRM &amp; reports</h3>
      <p>Contacts, companies, CSAT, agent performance, and integrations like LeadSquared.</p>
    </article>
    <article class="landing-card">
      <span class="landing-card-icon landing-card-icon-emerald" aria-hidden="true">✉</span>
      <h3>Professional email</h3>
      <p>Custom reply domain and support email after DNS setup, plus API email continuity.</p>
    </article>
  </div>
  <p class="pricing-includes-foot">See the <a href="<%= guide_path %>">User Guide</a> for step-by-step setup.</p>
</section>

<section class="landing-section">
  <div class="landing-section-head">
    <h2>How billing works</h2>
    <p>Go live on Starter in minutes with a 14-day trial. Upgrade when your team outgrows the Starter limits.</p>
  </div>
  <ol class="landing-steps">
    <li>
      <span class="landing-step-num">1</span>
      <div>
        <strong>Create a workspace</strong>
        <p><a href="/app/auth/signup">Sign up</a> — you start on the <strong>Starter</strong> plan with a 14-day trial automatically.</p>
      </div>
    </li>
    <li>
      <span class="landing-step-num">2</span>
      <div>
        <strong>Open Billing</strong>
        <p>Sign in as admin and go to <strong>Settings → Billing</strong> in your dashboard.</p>
      </div>
    </li>
    <li>
      <span class="landing-step-num">3</span>
      <div>
        <strong>Choose Growth or Business</strong>
        <p>Pick monthly or annual billing and pay with Pesapal — mobile money, M-Pesa, or card.</p>
      </div>
    </li>
    <li>
      <span class="landing-step-num">4</span>
      <div>
        <strong>Start supporting customers</strong>
        <p>Agent seats and Copilot allowance update automatically after payment succeeds.</p>
      </div>
    </li>
  </ol>
</section>

<section class="landing-section pricing-compare-section">
  <div class="landing-section-head">
    <h2>Compare plans at a glance</h2>
  </div>
  <div class="pricing-compare-wrap">
    <table class="pricing-compare-table">
      <thead>
        <tr>
          <th scope="col">Feature</th>
          <% converra_plans.each do |_slug, plan| %>
            <th scope="col"><%= plan['name'] %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th scope="row">Monthly price</th>
          <% converra_plans.each do |_slug, plan| %>
            <td>
              <% if plan['trial_days'].to_i.positive? %>
                <%= number_with_delimiter(plan['price_ugx']) %> UGX<br>
                <span class="pricing-compare-note"><%= plan['trial_days'] %>-day trial</span>
              <% elsif plan['price_ugx'].to_i.zero? %>
                Free
              <% else %>
                <%= number_with_delimiter(plan['price_ugx']) %> UGX
              <% end %>
            </td>
          <% end %>
        </tr>
        <tr>
          <th scope="row">Agent seats</th>
          <% converra_plans.each do |_slug, plan| %>
            <td><%= plan.dig('limits', 'agents') %></td>
          <% end %>
        </tr>
        <tr>
          <th scope="row">Copilot replies / month</th>
          <% converra_plans.each do |_slug, plan| %>
            <td><%= number_with_delimiter(plan.dig('limits', 'captain_responses')) %></td>
          <% end %>
        </tr>
        <tr>
          <th scope="row">All channels &amp; features</th>
          <% converra_plans.each do |_slug, _plan| %>
            <td><span class="pricing-check" aria-label="Included">✓</span></td>
          <% end %>
        </tr>
        <tr>
          <th scope="row">Annual billing</th>
          <% converra_plans.each do |_slug, plan| %>
            <td>
              <% if plan['annual_price_ugx'].to_i.positive? %>
                <%= number_with_delimiter(plan['annual_price_ugx']) %> UGX/yr
              <% else %>
                —
              <% end %>
            </td>
          <% end %>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<section class="landing-section landing-section-alt pricing-faq">
  <div class="landing-section-head">
    <h2>Common questions</h2>
  </div>
  <div class="pricing-faq-grid">
    <article class="landing-card landing-card-compact">
      <h3>Do I need a credit card to start?</h3>
      <p>No credit card is required to start. Starter includes a 14-day trial; after that, pay 30,000 UGX/month via Pesapal or upgrade to Growth or Business from Settings → Billing.</p>
    </article>
    <article class="landing-card landing-card-compact">
      <h3>Is setup included in monthly plan price?</h3>
      <p>No. Setup and training are billed as a one-time onboarding fee of <%= number_with_delimiter(onboarding_fee_ugx) %> UGX for all new clients.</p>
    </article>
    <article class="landing-card landing-card-compact">
      <h3>What counts as an agent?</h3>
      <p>Each team member with login access to reply to conversations counts toward your agent seat limit. Admins who only manage settings can be configured separately.</p>
    </article>
    <article class="landing-card landing-card-compact">
      <h3>What is Copilot?</h3>
      <p>Copilot is <%= installation_brand_name %>'s AI assistant — auto-replies and agent draft suggestions powered by <%= installation_captain_name %>. Usage resets monthly per plan.</p>
    </article>
    <article class="landing-card landing-card-compact">
      <h3>Can I switch plans later?</h3>
      <p>Yes. Upgrade or schedule a downgrade from Settings → Billing. Changes apply after payment or at the end of your billing period.</p>
    </article>
  </div>
</section>

<section class="landing-cta-band">
  <h2>Ready to unify your support channels?</h2>
  <p>Start your 14-day Starter trial — connect WhatsApp, email, and chat in one workspace.</p>
  <div class="landing-hero-actions">
    <a href="/app/auth/signup" class="landing-btn landing-btn-primary">Start 14-day trial</a>
    <a href="mailto:info@samabrains.com" class="landing-btn landing-btn-ghost">Talk to us</a>
  </div>
</section>

<footer class="landing-footer">
  <nav aria-label="Footer">
    <a href="<%= guide_path %>">User Guide</a>
    <a href="<%= pricing_path %>">Pricing</a>
    <a href="<%= "#{legal_site_url}/privacy" %>">Privacy</a>
    <a href="<%= "#{legal_site_url}/terms" %>">Terms</a>
    <a href="mailto:info@samabrains.com">Contact</a>
  </nav>
  <p>© <%= Time.current.year %> SamaBrains Solutions · <%= installation_brand_name %></p>
</footer>
