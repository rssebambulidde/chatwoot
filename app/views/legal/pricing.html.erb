<% content_for :title do %>Pricing | <%= installation_brand_name %><% end %>
<% content_for :meta_description do %>
  <%= installation_brand_name %> plans in UGX: Starter (free), Growth, and Business. Pay with Pesapal — M-Pesa, mobile money, and cards.
<% end %>

<h1>Pricing</h1>
<p class="lead">
  Choose a workspace plan for <%= installation_brand_name %>. All prices are in
  <strong>UGX per month</strong>. Pay securely with Pesapal after you sign in as a workspace admin.
</p>

<% if @payment_notice == 'success' %>
  <p style="padding:1rem;background:#ecfdf5;border:1px solid #86efac;border-radius:0.5rem;margin-bottom:1.25rem;">
    <strong>Payment received.</strong> Your plan will update shortly. Refresh the app or open
    <strong>Settings → Billing</strong> to confirm.
  </p>
<% elsif @payment_notice == 'cancelled' %>
  <p style="padding:1rem;background:#fef2f2;border:1px solid #fecaca;border-radius:0.5rem;margin-bottom:1.25rem;">
    Payment was cancelled. You can try again when ready.
  </p>
<% end %>

<div class="guide-card-grid">
  <% converra_plans.each do |slug, plan| %>
    <div class="guide-card" style="cursor:default;background:#fff;">
      <strong><%= plan['name'] %></strong>
      <span style="display:block;margin:0.5rem 0 0.75rem;font-size:1.25rem;color:#0f172a;font-weight:700;">
        <% if plan['price_ugx'].to_i.zero? %>
          Free
        <% else %>
          <%= number_with_delimiter(plan['price_ugx']) %> UGX<span style="font-size:0.875rem;font-weight:500;color:#64748b;">/mo</span>
        <% end %>
      </span>
      <ul style="font-size:0.875rem;color:#475569;padding-left:1rem;margin:0 0 1rem;">
        <li><%= plan.dig('limits', 'agents') %> agent<%= plan.dig('limits', 'agents').to_i == 1 ? '' : 's' %></li>
        <li><%= plan.dig('limits', 'inboxes') %> inbox<%= plan.dig('limits', 'inboxes').to_i == 1 ? '' : 'es' %></li>
        <li><%= number_with_delimiter(plan['conversations_monthly']) %> conversations / month</li>
        <% if plan['non_web_inboxes'].to_i.zero? %>
          <li>Website chat only</li>
        <% else %>
          <li>Email &amp; messaging channels</li>
        <% end %>
        <% if plan.dig('limits', 'captain_responses').to_i.positive? %>
          <li><%= plan.dig('limits', 'captain_responses') %> Captain AI replies / month</li>
        <% end %>
      </ul>
      <% if plan['price_ugx'].to_i.zero? %>
        <a href="/app/auth/signup" style="font-weight:600;">Get started free</a>
      <% elsif converra_billing_enabled? %>
        <a href="/app/login" style="font-weight:600;">Sign in to subscribe</a>
      <% else %>
        <a href="mailto:info@samabrains.com" style="font-weight:600;">Contact sales</a>
      <% end %>
    </div>
  <% end %>
</div>

<h2>How billing works</h2>
<ol>
  <li><a href="/app/auth/signup">Create a workspace</a> — you start on the free <strong>Starter</strong> plan.</li>
  <li>Sign in as admin and open <strong>Settings → Billing</strong>.</li>
  <li>Choose <strong>Growth</strong> or <strong>Business</strong> and pay with Pesapal.</li>
  <li>Your limits and features update automatically after payment.</li>
</ol>

<p>
  Questions? <a href="mailto:info@samabrains.com">info@samabrains.com</a> ·
  <a href="<%= guide_path %>">User Guide</a>
</p>
