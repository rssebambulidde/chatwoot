<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : installation_brand_name %></title>
    <% if content_for?(:meta_description) %>
      <meta name="description" content="<%= yield(:meta_description).squish %>">
    <% end %>
    <link rel="canonical" href="<%= legal_site_url %><%= request.path == '/' ? '' : request.path %>">
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: #f8fafc;
        color: #1e293b;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      .site-header {
        background: #fff;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 1.5rem;
      }
      .site-header-inner {
        max-width: 48rem;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .site-header img { height: 2rem; width: auto; display: block; }
      .site-header a.brand { text-decoration: none; }
      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 1rem;
        font-size: 0.875rem;
      }
      .site-nav a {
        color: #2563eb;
        text-decoration: none;
        font-weight: 500;
      }
      .site-nav a:hover { text-decoration: underline; }
      .container {
        max-width: 48rem;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }
      .hero {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #e2e8f0;
      }
      .eyebrow {
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #2563eb;
        margin-bottom: 0.5rem;
      }
      h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        color: #0f172a;
      }
      .lead {
        font-size: 1.0625rem;
        color: #334155;
        margin-bottom: 0;
      }
      section { margin-bottom: 1.75rem; }
      h2 {
        font-size: 1.125rem;
        font-weight: 600;
        margin: 0 0 0.5rem;
        color: #0f172a;
      }
      p, li { margin-bottom: 0.75rem; font-size: 0.9375rem; }
      ul { padding-left: 1.25rem; margin-bottom: 0.5rem; }
      a { color: #2563eb; }
      .updated { font-size: 0.875rem; color: #64748b; margin-bottom: 2rem; }
      .footer {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e2e8f0;
        font-size: 0.875rem;
        color: #64748b;
      }
      .footer a { margin-right: 1rem; }
      .guide-card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
        gap: 1rem;
        margin: 1.25rem 0;
      }
      .guide-card {
        display: block;
        padding: 1rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        text-decoration: none;
        color: inherit;
        background: #f8fafc;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/">
          <img src="<%= installation_logo_url %>" alt="<%= installation_brand_name %>">
        </a>
        <nav class="site-nav" aria-label="Site">
          <a href="<%= guide_path %>">User Guide</a>
          <a href="<%= pricing_path %>">Pricing</a>
          <a href="<%= "#{legal_site_url}/privacy" %>">Privacy Policy</a>
          <a href="<%= "#{legal_site_url}/terms" %>">Terms of Service</a>
          <a href="/app/auth/signup">Sign up</a>
          <a href="/app/login">Sign in</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <%= yield %>
    </main>
  </body>
</html>
