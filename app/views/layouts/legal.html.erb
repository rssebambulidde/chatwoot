<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : installation_brand_name %></title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: #f8fafc;
        color: #1e293b;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      .header {
        background: #fff;
        border-bottom: 1px solid #e2e8f0;
        padding: 1.25rem 1.5rem;
        text-align: center;
      }
      .header img { height: 2rem; width: auto; }
      .header a { text-decoration: none; }
      .container {
        max-width: 42rem;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }
      h1 {
        font-size: 1.875rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #0f172a;
      }
      .updated { font-size: 0.875rem; color: #64748b; margin-bottom: 2rem; }
      h2 {
        font-size: 1.125rem;
        font-weight: 600;
        margin: 1.75rem 0 0.5rem;
        color: #0f172a;
      }
      p, li { margin-bottom: 0.75rem; font-size: 0.9375rem; }
      ul { padding-left: 1.25rem; margin-bottom: 1rem; }
      a { color: #2563eb; }
      .footer {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e2e8f0;
        font-size: 0.875rem;
        color: #64748b;
      }
      .footer a { margin-right: 1rem; }
    </style>
  </head>
  <body>
    <header class="header">
      <a href="/app/login">
        <img src="<%= installation_logo_url %>" alt="<%= installation_brand_name %>">
      </a>
    </header>
    <main class="container">
      <%= yield %>
    </main>
  </body>
</html>
