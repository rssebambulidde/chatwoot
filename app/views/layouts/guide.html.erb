<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : "User Guide | #{installation_brand_name}" %></title>
    <% if content_for?(:meta_description) %>
      <meta name="description" content="<%= yield(:meta_description).squish %>">
    <% end %>
    <link rel="canonical" href="<%= legal_site_url %><%= request.path %>">
    <%= render 'layouts/installation_favicon' %>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: #f8fafc;
        color: #1e293b;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      .site-header {
        background: #fff;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 1.5rem;
      }
      .site-header-inner {
        max-width: 72rem;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .site-header img { height: 2rem; width: auto; display: block; }
      .site-header a.brand { text-decoration: none; }
      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 1rem;
        font-size: 0.875rem;
      }
      .site-nav a {
        color: #2563eb;
        text-decoration: none;
        font-weight: 500;
      }
      .site-nav a:hover { text-decoration: underline; }
      .site-nav a.is-active { color: #0f172a; text-decoration: none; }
      .guide-shell {
        max-width: 72rem;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        display: grid;
        grid-template-columns: 14rem minmax(0, 1fr);
        gap: 2.5rem;
        align-items: start;
      }
      @media (max-width: 768px) {
        .guide-shell {
          display: flex;
          flex-direction: column;
          padding: 1rem 1rem 3rem;
          gap: 1rem;
        }
        .site-header { padding: 0.75rem 1rem; }
        .site-header-inner { gap: 0.75rem; }
        .site-nav {
          width: 100%;
          flex-wrap: nowrap;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          padding-bottom: 0.125rem;
        }
        .site-nav::-webkit-scrollbar { display: none; }
        .site-nav a { white-space: nowrap; flex-shrink: 0; }
        .guide-content {
          padding: 1.25rem 1rem;
          border-radius: 0.375rem;
        }
        .guide-content h1 {
          font-size: 1.5rem;
          line-height: 1.25;
        }
        .guide-content h2 { font-size: 1.0625rem; margin-top: 1.5rem; }
        .guide-content .lead { font-size: 1rem; }
        .guide-card-grid { grid-template-columns: 1fr; }
        .guide-sidebar {
          position: static;
          padding: 0;
          border: none;
          background: transparent;
        }
        .guide-sidebar-details {
          background: #fff;
          border: 1px solid #e2e8f0;
          border-radius: 0.5rem;
          overflow: hidden;
        }
        .guide-sidebar-toggle {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 0.75rem;
          padding: 0.875rem 1rem;
          font-size: 0.9375rem;
          font-weight: 600;
          color: #0f172a;
          cursor: pointer;
          list-style: none;
          user-select: none;
        }
        .guide-sidebar-toggle::-webkit-details-marker { display: none; }
        .guide-sidebar-toggle::after {
          content: '▼';
          font-size: 0.65rem;
          color: #64748b;
          transition: transform 0.15s ease;
        }
        .guide-sidebar-details[open] .guide-sidebar-toggle::after {
          transform: rotate(180deg);
        }
        .guide-sidebar-body {
          padding: 0 1rem 1rem;
          border-top: 1px solid #e2e8f0;
        }
        .guide-sidebar-body h2 { margin-top: 1rem; }
        .guide-sidebar a {
          min-height: 2.75rem;
          display: flex;
          align-items: center;
        }
        .guide-callout,
        .guide-content .cta-box {
          padding: 0.875rem 1rem;
        }
      }
      @media (min-width: 769px) {
        .guide-sidebar-toggle { display: none; }
        .guide-sidebar-body { display: block; }
      }
      .guide-sidebar {
        position: sticky;
        top: 1.5rem;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 1rem;
      }
      .guide-sidebar h2 {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #64748b;
        margin-bottom: 0.75rem;
      }
      .guide-sidebar nav { display: flex; flex-direction: column; gap: 0.25rem; }
      .guide-nav-group { margin-bottom: 1rem; }
      .guide-nav-group:last-child { margin-bottom: 0; }
      .guide-nav-group h3 {
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #94a3b8;
        margin: 0.75rem 0 0.375rem 0.625rem;
      }
      .guide-nav-group:first-child h3 { margin-top: 0; }
      .guide-sidebar a {
        display: block;
        padding: 0.5rem 0.625rem;
        border-radius: 0.375rem;
        font-size: 0.875rem;
        color: #334155;
        text-decoration: none;
        font-weight: 500;
      }
      .guide-sidebar a:hover { background: #f1f5f9; color: #0f172a; }
      .guide-sidebar a.is-active { background: #eff6ff; color: #1d4ed8; }
      .guide-content {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 2rem;
        min-width: 0;
      }
      .guide-content h1 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        color: #0f172a;
      }
      .guide-content h2 {
        font-size: 1.125rem;
        font-weight: 600;
        margin: 1.75rem 0 0.5rem;
        color: #0f172a;
      }
      .guide-content h3 {
        font-size: 1rem;
        font-weight: 600;
        margin: 1.25rem 0 0.375rem;
        color: #0f172a;
      }
      .guide-content p, .guide-content li { margin-bottom: 0.75rem; font-size: 0.9375rem; }
      .guide-content ul, .guide-content ol { padding-left: 1.25rem; margin-bottom: 0.75rem; }
      .guide-content a {
        color: #2563eb;
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      .guide-content img { max-width: 100%; height: auto; }
      .guide-content pre {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        padding: 0.875rem 1rem;
        margin: 1rem 0;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 0.375rem;
        font-size: 0.8125rem;
        line-height: 1.5;
      }
      .guide-content code {
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      .guide-content pre code {
        word-break: normal;
        overflow-wrap: normal;
        white-space: pre;
      }
      .guide-content kbd {
        font-family: inherit;
        font-size: 0.8125rem;
        padding: 0.125rem 0.375rem;
        border: 1px solid #cbd5e1;
        border-radius: 0.25rem;
        background: #f1f5f9;
      }
      .guide-content .lead { font-size: 1.0625rem; color: #334155; margin-bottom: 1.25rem; }
      .guide-content .cta-box {
        margin-top: 2rem;
        padding: 1.25rem;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 0.5rem;
      }
      .guide-content .cta-box p:last-child { margin-bottom: 0; }
      .guide-card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
        gap: 1rem;
        margin: 1.25rem 0;
      }
      .guide-card {
        display: block;
        padding: 1rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        text-decoration: none;
        color: inherit;
        background: #f8fafc;
      }
      .guide-card:hover { border-color: #93c5fd; background: #eff6ff; }
      .guide-card strong { display: block; color: #0f172a; margin-bottom: 0.25rem; }
      .guide-card span { font-size: 0.875rem; color: #64748b; }
      .guide-table,
      .guide-content table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
        margin: 1rem 0;
      }
      .guide-table th,
      .guide-table td,
      .guide-content table th,
      .guide-content table td {
        padding: 0.5rem 0.75rem;
        border: 1px solid #e2e8f0;
        text-align: left;
        vertical-align: top;
      }
      .guide-table thead th,
      .guide-content table thead th {
        background: #f8fafc;
        font-weight: 600;
        color: #0f172a;
      }
      .guide-table code,
      .guide-content table code {
        font-size: 0.8125rem;
        background: #f1f5f9;
        padding: 0.1rem 0.35rem;
        border-radius: 0.25rem;
      }
      @media (max-width: 768px) {
        .guide-table-wrap,
        .guide-content .guide-table,
        .guide-content table {
          display: block;
          width: 100%;
          max-width: 100%;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
        }
      }
      .guide-callout {
        margin: 1.25rem 0;
        padding: 1rem 1.25rem;
        background: #fffbeb;
        border: 1px solid #fcd34d;
        border-radius: 0.5rem;
        font-size: 0.9375rem;
        color: #334155;
      }
      .guide-checklist { list-style: none; padding-left: 0; }
      .guide-checklist li {
        padding: 0.35rem 0 0.35rem 1.5rem;
        position: relative;
      }
      .guide-checklist li::before {
        content: '☐';
        position: absolute;
        left: 0;
        color: #2563eb;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/">
          <img src="<%= installation_logo_url %>" alt="<%= installation_brand_name %>">
        </a>
        <nav class="site-nav" aria-label="Site">
          <a href="<%= guide_path %>" class="is-active">User Guide</a>
          <a href="<%= pricing_path %>">Pricing</a>
          <a href="<%= "#{legal_site_url}/privacy" %>">Privacy Policy</a>
          <a href="<%= "#{legal_site_url}/terms" %>">Terms of Service</a>
          <a href="/app/auth/signup">Sign up</a>
          <a href="/app/login">Sign in</a>
        </nav>
      </div>
    </header>
    <div class="guide-shell">
      <%= render 'legal/guide/nav' %>
      <main class="guide-content">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
